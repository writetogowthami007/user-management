{
  "title": "user-management-service",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"user-management-service\"}[1m])) by (uri, method)",
          "legendFormat": "{{method}} {{uri}}"
        }
      ]
    },
    {
      "title": "HTTP P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"user-management-service\"}[5m])) by (le, uri)) * 1000",
          "legendFormat": "{{uri}}"
        }
      ]
    }
  ]
}

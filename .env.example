# =============================================================================
# Copy to ".env" for local overrides. Never commit ".env".
#
# This file documents variables only — no production or shared secrets belong
# here. Leave a line empty to use the Docker Compose local-dev default for that
# variable (see docker-compose.yml). For anything beyond your laptop, set
# strong unique values (especially JWT_SECRET and all passwords).
# =============================================================================

# PostgreSQL (container bootstrap)
POSTGRES_DB=user_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Runtime DB user (must match docker/postgres/init expectations unless you change init)
APP_DB_USERNAME=app_user
APP_DB_PASSWORD=

# Flyway (migration superuser)
FLYWAY_USER=
FLYWAY_PASSWORD=

# JWT signing key: Base64 that decodes to at least 32 bytes, e.g.:
#   openssl rand -base64 32
JWT_SECRET=

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
TRACING_SAMPLING_PROBABILITY=1.0
RATE_LIMIT_TRUST_FORWARDED_FOR=false
RATE_LIMIT_MAX_CLIENTS=10000

# Grafana UI (override defaults if you like)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
